{
  "name": "@tycoslide/components",
  "version": "0.2.0",
  "description": "Standard component library for tycoslide presentations",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist/"],
  "scripts": {
    "build": "tsc",
    "test": "tsc --project tsconfig.test.json && tsx --test test/*.test.ts",
    "typecheck": "tsc --project tsconfig.test.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tycoworks/tycoslide.git",
    "directory": "packages/components"
  },
  "dependencies": {
    "mermaid": "^11.4.0",
    "mdast-util-gfm-strikethrough": "^2.0.0",
    "micromark-extension-gfm-strikethrough": "^2.0.0",
    "remark-directive": "^4.0.0",
    "remark-ins": "^1.2.3",
    "remark-parse": "^11.0.0",
    "shiki": "^4.0.0",
    "@tycoslide/core": "^0.2.0",
    "unified": "^11.0.5",
    "@types/mdast": "^4.0.0",
    "@types/unist": "^3.0.0"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.0.0",
    "@types/node": "^20.19.30",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
