{
  "name": "tycoslide-components",
  "version": "1.0.0",
  "description": "Standard component definitions for tycoslide",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc --project tsconfig.test.json && tsx --test test/*.test.ts",
    "typecheck": "tsc --project tsconfig.test.json",
    "clean": "rm -rf dist"
  },
  "type": "module",
  "dependencies": {
    "mermaid": "^11.4.0",
    "remark-directive": "^4.0.0",
    "remark-parse": "^11.0.0",
    "shiki": "^4.0.0",
    "tycoslide": "*",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.0.0",
    "@types/node": "^20.19.30",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
