{
  "name": "@tycoslide/cli",
  "version": "0.3.0",
  "description": "CLI for tycoslide — build PowerPoint presentations from markdown",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tycoslide": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "test": "tsx --test test/*.test.ts"
  },
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tycoworks/tycoslide.git",
    "directory": "packages/cli"
  },
  "dependencies": {
    "@tycoslide/core": "^0.3.0",
    "@tycoslide/sdk": "^0.3.0",
    "commander": "^14.0.3",
    "debug": "^4.4.3"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^20.19.30",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
