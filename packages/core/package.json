{
  "name": "tycoslide",
  "version": "1.0.0",
  "description": "Declarative slide generation library built on pptxgenjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "tycoslide": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "tsc && chmod +x dist/cli/index.js",
    "typecheck": "tsc --project tsconfig.test.json",
    "test": "tsc --project tsconfig.test.json && tsx --test test/*.test.ts"
  },
  "keywords": [
    "powerpoint",
    "slides",
    "pptx",
    "presentation"
  ],
  "author": "tycoworks",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "debug": "^4.4.3",
    "hono": "^4.11.9",
    "image-size": "^1.1.1",
    "@tycoworks/pptxgenjs": "^4.0.1",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fontsource/inter": "^5.0.0",
    "@types/debug": "^4.1.12",
    "@types/node": "^20.19.30",
"playwright": "^1.58.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
