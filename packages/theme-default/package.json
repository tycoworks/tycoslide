{
  "name": "@tycoslide/theme-default",
  "version": "0.2.1",
  "description": "Default reference theme for tycoslide — Inter font, purple/navy palette, 14 layouts",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/",
    "assets/"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tycoworks/tycoslide.git",
    "directory": "packages/theme-default"
  },
  "dependencies": {
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.0.0",
    "@tycoslide/core": "^0.2.0",
    "@tycoslide/components": "^0.2.0"
  },
  "devDependencies": {
    "@material-design-icons/svg": "^0.14.0",
    "@types/node": "^20.19.30",
    "typescript": "^5.3.0"
  }
}
